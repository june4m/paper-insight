# ─── Server ───────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed CORS origins (frontend URL)
CORS_ORIGIN=http://localhost:3000

# ─── Google Gemini (NFR-02: never commit the real key) ────
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
CHAT_MODEL=gemini-2.0-flash
EMBED_MODEL=text-embedding-004

# ─── Storage ──────────────────────────────────────────────
STORAGE_DIR=./storage
# Max upload size in bytes (BR-02 -> 10 MB)
MAX_FILE_BYTES=10485760

# ─── Metadata DB (SQLite) ─────────────────────────────────
DB_PATH=./data/paper-insight.db

# ─── Vector store ─────────────────────────────────────────
# "chroma"  -> use a running ChromaDB server (recommended, per spec)
# "memory"  -> built-in JS cosine store (no external server; dev/demo fallback)
VECTOR_BACKEND=chroma
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=paper_insight_chunks

# ─── RAG tuning ───────────────────────────────────────────
CHUNK_TOKENS=600
CHUNK_OVERLAP=80
TOP_K=4
# Max cosine distance for a chunk to count as "relevant" (BR-04 gate)
SIM_MAX_DISTANCE=0.75
